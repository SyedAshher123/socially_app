<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer gradient ring -->
    <item>
        <shape
            android:shape="oval">
            <gradient
                android:type="sweep"
                android:startColor="#833AB4"
                android:centerColor="#FD1D1D"
                android:endColor="#833AB4"
                android:useLevel="false" />
        </shape>
    </item>

    <!-- Inner transparent circle to create ring effect -->
    <item
        android:left="6dp"
        android:right="6dp"
        android:top="6dp"
        android:bottom="6dp">
        <shape
            android:shape="oval">
            <solid android:color="@android:color/white" />
        </shape>
    </item>
</layer-list>
