<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:paddingHorizontal="12dp">

    <LinearLayout
        android:id="@+id/loginRootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="22dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_marginTop="150dp"
            android:layout_marginBottom="32dp"
            android:src="@drawable/socially"
            />

        <EditText
            android:id="@+id/usernameField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:textColorHint="@android:color/darker_gray"
            android:fontFamily="@font/instagram_sans"
            android:textColor="#000000" />

        <EditText
            android:id="@+id/passwordField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password"
            android:inputType="textPassword"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:textColorHint="@android:color/darker_gray"
            android:fontFamily="@font/instagram_sans"
            android:textColor="#000000"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/forgotPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Forgot password?"
            android:textSize="14sp"
            android:textColor="#8B3A3A"
            android:gravity="end"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/instagram_sans" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Log in"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:layout_marginTop="20dp"
            android:stateListAnimator="@null"
            android:backgroundTint="@color/brown"
            app:cornerRadius="6dp"
            app:rippleColor="#22000000"
            android:fontFamily="@font/instagram_sans" />

        <LinearLayout
            android:id="@+id/dividerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="70dp"
            android:layout_marginBottom="24dp">

            <View
                android:id="@+id/dividerLeft"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:background="#33000000" />

            <TextView
                android:id="@+id/orText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OR"
                android:textColor="#99000000"
                android:textSize="14sp" />

            <View
                android:id="@+id/dividerRight"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="#33000000" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/signUpLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/noAccountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don’t have an account?"
                android:textSize="12sp"
                android:textColor="@color/offwhite"
                android:fontFamily="@font/instagram_sans" />

            <Space
                android:id="@+id/signUpSpacer"
                android:layout_width="4dp"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/signUpText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign up"
                android:textSize="12sp"
                android:textColor="@color/light_brown"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/instagram_sans" />
        </LinearLayout>

        <View
            android:id="@+id/bottomDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33000000"
            android:layout_marginTop="300dp" />

        <TextView
            android:id="@+id/footerAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Socially"
            android:textSize="20sp"
            android:textColor="#8B3A3A"
            android:layout_marginBottom="20dp"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:fontFamily="@font/instagram_sans_headline" />

    </LinearLayout>
</ScrollView>
