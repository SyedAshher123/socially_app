<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_home_feed"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_height="match_parent"
    android:layout_width="match_parent">

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBarContainer"
        android:paddingStart="12dp"
        android:gravity="center_vertical"
        android:paddingEnd="12dp"
        android:layout_height="56dp"
        android:layout_width="match_parent">

        <ImageView
            android:id="@+id/iv_camera"
            android:layout_alignParentStart="true"
            android:layout_width="34dp"
            android:src="@drawable/brown_camera_new"
            android:layout_height="34dp"
            android:layout_centerVertical="true"
            android:contentDescription="camera"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/tv_title"
            android:layout_marginTop="10dp"
            android:layout_centerInParent="true"
            android:src="@drawable/socially_logo"
            android:layout_width="wrap_content"
            android:layout_height="40dp"/>

        <ImageView
            android:id="@+id/iv_tv"
            android:layout_marginEnd="12dp"
            android:src="@drawable/reels_brown"
            android:layout_toStartOf="@id/iv_message"
            android:layout_height="32dp"
            android:layout_width="32dp"
            android:layout_centerVertical="true"
            android:contentDescription="tv"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/iv_message"
            android:src="@drawable/chat_send"
            android:layout_width="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_height="30dp"
            android:contentDescription="messages"
            android:clickable="true"
            android:focusable="true"/>
    </RelativeLayout>

    <!-- Dynamic Stories RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewStories"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:orientation="horizontal"
        android:paddingStart="9dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        tools:listitem="@layout/story_item_layout"/>

    <!-- Divider -->
    <View
        android:id="@+id/topDividerLine"
        android:layout_width="match_parent"
        android:background="#33000000"
        android:layout_height="1dp" />

    <!-- RecyclerView for posts -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewPosts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        tools:listitem="@layout/post_item" />

    <!-- Bottom Nav -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <View
            android:id="@+id/bottomNavDivider"
            android:background="#33000000"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="top" />

        <LinearLayout
            android:id="@+id/bottomNavBar"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:elevation="4dp"
            android:gravity="center"
            android:layout_height="64dp"
            android:background="@color/white">

            <ImageView
                android:id="@+id/bottomNavHome"
                android:layout_height="25dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:contentDescription="home"
                android:src="@drawable/home_filled"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/bottomNavSearch"
                android:contentDescription="search"
                android:src="@drawable/search_canva"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="25dp"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/bottomNavCreate"
                android:layout_width="0dp"
                android:contentDescription="add"
                android:layout_height="25dp"
                android:src="@drawable/upload_plus_bottom_nav"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/bottomNavLikes"
                android:layout_width="0dp"
                android:layout_height="25dp"
                android:layout_weight="1"
                android:src="@drawable/heart_unfilled"
                android:contentDescription="likes"
                android:clickable="true"
                android:focusable="true"
                />

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/bottomNavProfile"
                android:contentDescription="profile"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="30dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
