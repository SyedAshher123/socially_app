<LinearLayout




    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="wrap_content">

    <!-- Header with profile pic + username -->
    <LinearLayout
        android:id="@+id/postItemContainer"
        android:layout_marginBottom="16dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_width="match_parent">

        <LinearLayout
            android:id="@+id/post1Header"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_marginTop="5dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/postProfileImage"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_pfp"
                />

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="username placeholder"
                android:textColor="@color/black"/>

        </LinearLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vpPostImages"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            />


        <RelativeLayout
            android:id="@+id/post1ActionsContainer"
            android:layout_marginTop="6dp"
            android:layout_width="match_parent"
            android:padding="12dp"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/post1ActionIcons"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/post1LikeIcon"
                    android:src="@drawable/black_heart"
                    android:layout_width="30dp"
                    android:layout_marginEnd="8dp"
                    android:layout_height="30dp" />

                <TextView
                    android:id="@+id/likesCounter"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="0"
                    android:textSize="21sp"
                    android:textColor="@color/black"
                    android:layout_marginEnd="12dp"/>

                <ImageView
                    android:id="@+id/post1CommentIcon"
                    android:layout_height="26dp"
                    android:layout_marginEnd="18dp"
                    android:layout_width="26dp"
                    android:src="@drawable/black_comment" />

                <ImageView
                    android:id="@+id/post1ShareIcon"
                    android:src="@drawable/black_send"
                    android:layout_height="26dp"
                    android:layout_width="26dp"
                    />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/post1Dots"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/post1DotActive"
                    android:layout_margin="2dp"
                    android:layout_height="6dp"
                    android:src="@drawable/brown_circle"
                    android:layout_width="6dp" />

                <ImageView
                    android:id="@+id/post1Dot1"
                    android:layout_margin="2dp"
                    android:layout_height="6dp"
                    android:layout_width="6dp"
                    android:src="@drawable/white_circle" />

                <ImageView
                    android:id="@+id/post1Dot2"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_margin="2dp"
                    android:src="@drawable/white_circle" />
            </LinearLayout>

            <ImageView
                android:id="@+id/post1SaveIcon"
                android:layout_alignParentEnd="true"
                android:layout_width="24dp"
                android:src="@drawable/save"
                android:layout_height="24dp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/postCaption"
            android:layout_marginTop="-22dp"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:text="caption placeholder"
            android:textSize="14sp"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/post1LikeRow"
            android:gravity="center_vertical"
            android:layout_marginTop="-10dp"
            android:orientation="horizontal"
            android:layout_height="wrap_content"
            android:paddingHorizontal="6dp"
            android:layout_width="match_parent">


        </LinearLayout>


    </LinearLayout>

</LinearLayout>
