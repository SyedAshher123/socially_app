<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_post_background_drawable"
    android:padding="16dp"
    >

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Share Post"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/instagram_sans_headline"
            android:textColor="@color/brown"/>

        <ImageView
            android:id="@+id/btnCloseDialog"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/brown_x"
            android:contentDescription="Close"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"/>

    <!-- Search bar -->
    <EditText
        android:id="@+id/etSearchChats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:hint="Search chats..."
        android:textColorHint="@color/light_brown"
        android:padding="12dp"
        android:background="@drawable/edittext_bg"
        android:drawableStart="@drawable/search"
        android:drawablePadding="8dp"/>

    <!-- Chat list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvShareChats"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:scrollbars="vertical"/>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmptyChats"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:text="No active chats found.\nStart a conversation first!"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="@android:color/darker_gray"
        android:visibility="gone"/>

</LinearLayout>