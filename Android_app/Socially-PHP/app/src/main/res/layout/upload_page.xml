<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:id="@+id/main"
    >

    <!-- Title at top -->
    <ImageView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="100dp"
        android:layout_marginTop="24dp"
        android:layout_centerHorizontal="true"
        android:src="@drawable/socially"/>

    <!-- Main Upload Content -->
    <LinearLayout
        android:id="@+id/uploadContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal"
        android:layout_below="@id/tv_title"
        android:layout_above="@id/uploadBottomNavDivider">

        <!-- Image selection square -->
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <FrameLayout
                android:id="@+id/imagePickerContainer"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:background="@drawable/upload_square"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_selectedImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_selectPrompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to select an image"
                android:textColor="@color/brown"
                android:textSize="14sp"
                android:layout_centerInParent="true"
                android:textStyle="bold"/>
        </RelativeLayout>

        <!-- Caption box -->
        <EditText
            android:id="@+id/et_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Write a caption..."
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="@drawable/rounded_edittext"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="4"
            android:gravity="top|start"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Upload button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_upload"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:text="Upload"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:fontFamily="@font/instagram_sans"
            android:textSize="16sp"
            app:cornerRadius="10dp"
            android:backgroundTint="@color/light_brown"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Cancel button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelButton"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="12dp"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="@color/brown"
            android:fontFamily="@font/instagram_sans"
            android:textSize="16sp"
            android:backgroundTint="@color/white"
            app:cornerRadius="10dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/light_brown"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Divider above bottom nav -->
    <View
        android:id="@+id/uploadBottomNavDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_above="@id/uploadBottomNavigation"
        android:background="#E0E0E0" />

    <!-- Bottom Navigation Tabs -->
    <LinearLayout
        android:id="@+id/uploadBottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="4dp">

        <!-- Post Tab -->
        <LinearLayout
            android:id="@+id/postTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/postTabText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Post"
                android:textColor="@color/brown"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/instagram_sans"
                android:clickable="true"
                android:focusable="true"/>

            <View
                android:id="@+id/postTabIndicator"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginTop="4dp"
                android:background="@color/brown" />
        </LinearLayout>

        <!-- Story Tab -->
        <LinearLayout
            android:id="@+id/storyTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/storyTabText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Story"
                android:textColor="@android:color/darker_gray"
                android:textSize="16sp"
                android:fontFamily="@font/instagram_sans"
                android:clickable="true"
                android:focusable="true"
                />

            <View
                android:id="@+id/storyTabIndicator"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
