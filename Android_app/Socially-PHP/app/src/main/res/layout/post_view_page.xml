<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:id="@+id/main_post_view"
    android:fitsSystemWindows="true"
    >

    <!-- Top Bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:layout_alignParentTop="true"
        android:background="@android:color/white"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/back_button_login_page"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="Back"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Post"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/brown"
            android:layout_centerInParent="true"/>

        <ImageView
            android:id="@+id/moreOptions"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/black_more"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="More"/>
    </RelativeLayout>

    <!-- Scrollable Post Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topBar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Post Header with profile pic + username -->
            <LinearLayout
                android:id="@+id/postHeader"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_marginTop="8dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/postProfileImage"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/placeholder_pfp"/>

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:text="username"
                    android:textColor="@color/black"/>
            </LinearLayout>

            <!-- Post Images ViewPager -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpPostImages"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:clipToPadding="false"
                android:clipChildren="false"/>

            <!-- Actions Container -->
            <RelativeLayout
                android:id="@+id/postActionsContainer"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:padding="12dp"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/postActionIcons"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/postLikeIcon"
                        android:src="@drawable/like"
                        android:layout_width="28dp"
                        android:layout_marginEnd="6dp"
                        android:layout_height="28dp"
                        android:contentDescription="Like"/>

                    <TextView
                        android:id="@+id/likesCounter"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="0"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:layout_marginEnd="12dp"/>

                    <ImageView
                        android:id="@+id/postCommentIcon"
                        android:layout_height="28dp"
                        android:layout_marginEnd="12dp"
                        android:layout_width="28dp"
                        android:src="@drawable/comment"
                        android:contentDescription="Comment"/>

                    <ImageView
                        android:id="@+id/postShareIcon"
                        android:src="@drawable/share"
                        android:layout_height="28dp"
                        android:layout_width="28dp"
                        android:contentDescription="Share"/>
                </LinearLayout>

                <!-- Image Dots Indicator -->
                <LinearLayout
                    android:id="@+id/postDots"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/postDotActive"
                        android:layout_margin="2dp"
                        android:layout_height="6dp"
                        android:src="@drawable/brown_circle"
                        android:layout_width="6dp"
                        android:contentDescription="Active dot"/>

                    <ImageView
                        android:id="@+id/postDot1"
                        android:layout_margin="2dp"
                        android:layout_height="6dp"
                        android:layout_width="6dp"
                        android:src="@drawable/white_circle"
                        android:contentDescription="Dot 1"/>

                    <ImageView
                        android:id="@+id/postDot2"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_margin="2dp"
                        android:src="@drawable/white_circle"
                        android:contentDescription="Dot 2"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/postSaveIcon"
                    android:layout_alignParentEnd="true"
                    android:layout_width="24dp"
                    android:src="@drawable/save"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="Save"/>
            </RelativeLayout>

            <!-- Caption -->
            <TextView
                android:id="@+id/postCaption"
                android:padding="12dp"
                android:layout_width="match_parent"
                android:text="Loading caption..."
                android:textSize="14sp"
                android:textColor="@color/black"
                android:layout_height="wrap_content"/>

            <!-- Timestamp -->
            <TextView
                android:id="@+id/postTimestamp"
                android:paddingHorizontal="12dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:text="Just now"
                android:textSize="12sp"
                android:textColor="@android:color/darker_gray"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </ScrollView>

    <!-- Loading Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"/>
</RelativeLayout>