<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Text message (visible only for text messages) -->
    <TextView
        android:id="@+id/text_message_received"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/chat_bubble_received"
        android:textColor="@android:color/black"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Image message (visible only for image messages) -->
    <ImageView
        android:id="@+id/image_message_received"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:layout_marginTop="4dp"
        android:background="#FFFFFF"
        android:padding="4dp"
        android:visibility="gone" />

    <!-- Time -->
    <TextView
        android:id="@+id/text_message_time_received"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/darker_gray"
        android:textSize="10sp"
        android:layout_marginTop="4dp" />
    <include
        android:id="@+id/postItemContainer"
        layout="@layout/item_shared_post"
        android:visibility="gone" />

</LinearLayout>
